{
    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "configgen: Switch eden-emu (ROM genérica)",
            "type": "debugpy",
            "request": "launch",
            "module": "configgen.emulatorlauncher",
            "cwd": "${workspaceFolder}",
            "args": [
                "-p1index",
                "0",
                "-p1guid",
                "03004e526f0e0000a802000023020000",
                "-p1name",
                "PDP Xbox One Arctic White",
                "-p1nbbuttons",
                "11",
                "-p1nbhats",
                "1",
                "-p1nbaxes",
                "6",
                "-system",
                "switch",
                "-rom",
                "/penguintb/juegos/roms/switch/Donkey Kong Country Returns HD [01009D901BC56000][v0][US](nsw2u.com).nsp",
                "-gameinfoxml",
                "/tmp/game.xml",
                "-systemname",
                "Nintendo Switch"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PATH": "/home/manuel/proyectos/batocera-configgen:/home/manuel/.local/bin:/usr/local/bin:/usr/bin:/bin",
                "SDL_JOYSTICK_HIDAPI": "1",
                "SDL_JOYSTICK_HIDAPI_SWITCH": "1",
                "SDL_JOYSTICK_HIDAPI_XBOX": "1",
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
