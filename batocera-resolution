#!/bin/bash
# batocera-resolution — wrapper para Debian/KDE Wayland
# Implementa solo los subcomandos que usa configgen

case "$1" in
    currentMode)
        # 1. KDE Wayland via kscreen-doctor
        if command -v kscreen-doctor &>/dev/null && [ -n "$WAYLAND_DISPLAY" ]; then
            MODE=$(kscreen-doctor -o 2>/dev/null \
                | grep -E "Mode:.*\*" \
                | awk '{print $2}' \
                | head -1 \
                | cut -d@ -f1)
            if [ -n "$MODE" ]; then
                echo "$MODE"
                exit 0
            fi
        fi

        # 2. wlr-randr (compositors wlroots: sway, hyprland...)
        if command -v wlr-randr &>/dev/null && [ -n "$WAYLAND_DISPLAY" ]; then
            MODE=$(wlr-randr 2>/dev/null \
                | grep -E "^\s+[0-9]+x[0-9]+" \
                | grep "current" \
                | awk '{print $1}' \
                | head -1)
            if [ -n "$MODE" ]; then
                echo "$MODE"
                exit 0
            fi
        fi

        # 3. X11 fallback
        if command -v xrandr &>/dev/null && [ -n "$DISPLAY" ]; then
            MODE=$(xrandr 2>/dev/null \
                | grep '\*' \
                | awk '{print $1}' \
                | head -1)
            if [ -n "$MODE" ]; then
                echo "$MODE"
                exit 0
            fi
        fi

        # 4. Último recurso: leer desde /sys (no depende de nada)
        if [ -f /sys/class/drm/card*/modes ]; then
            head -1 /sys/class/drm/card*/modes 2>/dev/null | head -1
            exit 0
        fi

        echo "1920x1080"  # fallback hardcodeado
        ;;

    minTomaxResolution)
        # batocera usa esto para ajustar resolución mínima/máxima
        # en Debian lo dejamos como no-op (devuelve la actual)
        "$0" currentMode
        ;;

    setMode)
        # Cambio de resolución — no-op por ahora
        # Si en el futuro se necesita: kscreen-doctor output.1.mode.$2
        exit 0
        ;;
    currentResolution)
        "$0" currentMode
        ;;
    *)
        # Subcomandos desconocidos — no-op silencioso
        exit 0
        ;;
esac
