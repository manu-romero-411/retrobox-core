#!/usr/bin/env bash
# =============================================================================
# lutris-es-sync.sh
# Escanea todos los juegos instalados en Lutris (vía su base de datos SQLite)
# y genera un archivo <nombre>.lynx por cada uno en:
#   /var/penguin/juegos/retrobox/roms/lutris/
#
# Formato del enlace: lutris://rungameid/<id>
# El ID es interno de Lutris y depende de cada instalación.
# =============================================================================

set -uo pipefail

# ── Configuración ─────────────────────────────────────────────────────────────
DESTINO="/var/penguin/juegos/retrobox/roms/lutris"

# Rutas habituales de la base de datos de Lutris
LUTRIS_DB_CANDIDATES=(
    "${HOME}/.local/share/lutris/pga.db"
    "${HOME}/.var/app/net.lutris.Lutris/.local/share/lutris/pga.db"  # Flatpak
)

# ── Colores ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[ OK ]${NC}  $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERR ]${NC}  $*"; }

# ── Limpieza de nombre para nombre de archivo ──────────────────────────────────
limpiar_nombre() {
    local nombre="$1"
    nombre="${nombre//[\/\\:*?\"<>|]/-}"
    nombre="${nombre#"${nombre%%[![:space:]]*}"}"
    nombre="${nombre%"${nombre##*[![:space:]]}"}"
    echo "$nombre"
}

# ── Verificar dependencias ─────────────────────────────────────────────────────
if ! command -v sqlite3 &>/dev/null; then
    log_error "sqlite3 no está instalado. Instálalo con:\n* sudo apt install sqlite3 (debian)\n* sudo dnf install sqlite (fedora)\n* sudo pacman -S sqlite (arch)"
    exit 1
fi

# ── Localizar base de datos de Lutris ─────────────────────────────────────────
LUTRIS_DB=""
for candidate in "${LUTRIS_DB_CANDIDATES[@]}"; do
    if [[ -f "$candidate" ]]; then
        LUTRIS_DB="$candidate"
        break
    fi
done

if [[ -z "$LUTRIS_DB" ]]; then
    log_error "No se encontró la base de datos de Lutris en:"
    for c in "${LUTRIS_DB_CANDIDATES[@]}"; do
        log_error "  • $c"
    done
    log_error "Edita LUTRIS_DB_CANDIDATES si tu instalación está en otra ruta."
    exit 1
fi

log_info "Base de datos encontrada: ${LUTRIS_DB}"

# ── Crear directorio destino ───────────────────────────────────────────────────
if [[ ! -d "$DESTINO" ]]; then
    log_info "Creando directorio destino: ${DESTINO}"
    mkdir -p "$DESTINO"
fi

# ── Consultar juegos instalados ────────────────────────────────────────────────
# La tabla "games" contiene todos los juegos. Filtramos por installed=1
# para obtener solo los que están realmente instalados (no los de la biblioteca
# que aún no se han instalado).
# Columnas que nos interesan: id, name, runner
echo ""
log_info "Consultando juegos instalados en Lutris..."
echo ""

total=0

while IFS='|' read -r id nombre runner; do
    [[ -z "$id" || -z "$nombre" ]] && continue

    nombre_limpio="$(limpiar_nombre "$nombre")"
    enlace="lutris:rungameid/${id}"
    ruta_archivo="${DESTINO}/${nombre_limpio}.lynx"

    echo "$enlace" > "$ruta_archivo"
    log_ok "[${runner:-sin runner}] ${nombre_limpio}.lynx  →  ${enlace}"
    ((total++)) || true

done < <(
    sqlite3 "$LUTRIS_DB" \
        "SELECT id, name, runner FROM games WHERE installed=1 ORDER BY name;"
)

# ── Resumen ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}══════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  ✔  ${total} archivo(s) .lynx generados en:${NC}"
echo -e "${GREEN}     ${DESTINO}${NC}"
echo -e "${GREEN}══════════════════════════════════════════════════════════${NC}"
echo ""