#!/bin/bash

if test -z "${DISPLAY}"
then
    export DISPLAY=$(getLocalXDisplay)
fi

# Define the directory paths
configPath="${USERDATA}/emuconfigs/shadps4"
dlcPath="${USERDATA}/roms/ps4/DLC"

# Check if the directory exists, and create it if it doesn't
if [ ! -d "$configPath" ]; then
    mkdir -p "$configPath"
    if [ $? -eq 0 ]; then
        echo "Directory created successfully."
    else
        echo "Failed to create directory."
        exit 1
    fi
fi

if [ ! -d "$dlcPath" ]; then
    mkdir -p "$dlcPath"
    if [ $? -eq 0 ]; then
        echo "Directory created successfully."
    else
        echo "Failed to create directory."
        exit 1
    fi
fi

"${USERDATA}/resources/emulatorlauncher/emulatorlauncher.sh"  -system ps4 -rom config -emulator shadps4
